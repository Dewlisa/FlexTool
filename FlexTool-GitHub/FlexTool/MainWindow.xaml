<Window x:Class="FlexTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlexTool"
        Width="760" Height="500"
        MinWidth="480" MinHeight="280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="BluePrimary">#FF3A7BD5</Color>
        <Color x:Key="BlueLight">#FF5A9AE6</Color>
        <Color x:Key="BlueDark">#FF1E3A5F</Color>
        <Color x:Key="BorderBlue">#FF2A2A2E</Color>
        <Color x:Key="PanelDark">#FF0E0E10</Color>
        <Color x:Key="PanelMid">#FF141416</Color>
        <Color x:Key="SidebarBg">#FF111113</Color>
        <Color x:Key="ContentBg">#FF161618</Color>
        <Color x:Key="TextPrimary">#FFC8C8CC</Color>
        <Color x:Key="TextSecondary">#FF6E6E78</Color>

        <SolidColorBrush x:Key="BluePrimaryBrush" Color="{StaticResource BluePrimary}"/>
        <SolidColorBrush x:Key="BlueLightBrush" Color="{StaticResource BlueLight}"/>
        <SolidColorBrush x:Key="BlueDarkBrush" Color="{StaticResource BlueDark}"/>
        <SolidColorBrush x:Key="BorderBlueBrush" Color="{StaticResource BorderBlue}"/>
        <SolidColorBrush x:Key="PanelDarkBrush" Color="{StaticResource PanelDark}"/>
        <SolidColorBrush x:Key="PanelMidBrush" Color="{StaticResource PanelMid}"/>
        <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBg}"/>
        <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBg}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <!-- Top nav button style (parallelogram) -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="-1,1">
                            <Border x:Name="NavBd" BorderBrush="{StaticResource BluePrimaryBrush}" BorderThickness="1.5" Background="Transparent">
                                <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                <Border.RenderTransform>
                                    <SkewTransform AngleX="-15"/>
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="NavBd" Property="Background" Value="#223A7BD5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active top nav button style (parallelogram, filled) -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="-1,1">
                            <Border x:Name="NavBd" BorderBrush="{StaticResource BlueLightBrush}" BorderThickness="1.5" Background="#333A7BD5">
                                <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                <Border.RenderTransform>
                                    <SkewTransform AngleX="-15"/>
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBd" Property="Background" Value="#443A7BD5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar button style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window control button style -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button style (red hover) -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CCDC3545"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active sidebar button style -->
        <Style x:Key="SidebarButtonActiveStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource BluePrimaryBrush}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Launch card button style -->
        <Style x:Key="LaunchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{StaticResource BluePrimaryBrush}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TextBox style for pawn editor fields -->
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelDarkBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox toggle button -->
        <Style x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{StaticResource PanelDarkBrush}"
                                BorderBrush="{StaticResource BorderBlueBrush}" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="1" Data="M4 8L8 12L12 8" Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox style -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#3A7BD5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#225A9AE6"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="#303030"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Padding" Value="14,7,20,7"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#225A9AE6"/>
                                        <Setter Property="Foreground" Value="#303030"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#333A7BD5"/>
                                        <Setter Property="Foreground" Value="#303030"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="false">
                    <Setter Property="Opacity" Value="0.56"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Searchable editable ComboBox toggle -->
        <Style x:Key="DarkEditableComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="Transparent" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="1" Data="M4 8L8 12L12 8" Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Searchable/Editable ComboBox style with proper PART_EditableTextBox -->
        <Style x:Key="DarkSearchableComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelDarkBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="OuterBd" Background="{StaticResource PanelDarkBrush}"
                                    BorderBrush="{StaticResource BorderBlueBrush}" BorderThickness="1" CornerRadius="4"/>
                            <ToggleButton x:Name="ToggleButton" Style="{StaticResource DarkEditableComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     CaretBrush="White"
                                     BorderThickness="0"
                                     FontSize="11"
                                     Margin="6,3,24,3"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Stretch"
                                     Focusable="True"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                    <Border x:Name="DropDownBorder" Background="{StaticResource PanelDarkBrush}"
                                            BorderBrush="{StaticResource BluePrimaryBrush}" BorderThickness="1" CornerRadius="4" Margin="0,2,0,0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBd" Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="OuterBd" Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A7BD5"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1E1E1E"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1E1E"/>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#333A7BD5"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueDarkBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Slider thumb -->
        <Style x:Key="DarkSliderThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="ThumbEllipse" Fill="{StaticResource BluePrimaryBrush}"
                                 Width="14" Height="14"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbEllipse" Property="Fill" Value="{StaticResource BlueLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbEllipse" Property="Fill" Value="{StaticResource BlueLightBrush}"/>
                                <Setter TargetName="ThumbEllipse" Property="Width" Value="16"/>
                                <Setter TargetName="ThumbEllipse" Property="Height" Value="16"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Slider style -->
        <Style x:Key="DarkSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="20"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="TrackBackground" Height="4" CornerRadius="2"
                                    Background="{StaticResource BorderBlueBrush}" VerticalAlignment="Center"/>
                            <Canvas VerticalAlignment="Center" Height="14">
                                <Canvas.Clip>
                                    <RectangleGeometry Rect="0,-2,9999,18"/>
                                </Canvas.Clip>
                            </Canvas>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="{StaticResource BluePrimaryBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkSliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small card button style (for add/remove) -->
        <Style x:Key="CardSmallButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{StaticResource BluePrimaryBrush}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger small button style (for remove) -->
        <Style x:Key="CardDangerButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#44DC3545" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#88DC3545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ScrollBar thumb -->
        <Style x:Key="DarkScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBd" Background="#44FFFFFF" CornerRadius="4" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="{StaticResource BluePrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark vertical ScrollBar -->
        <Style x:Key="DarkScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ScrollViewer style -->
        <Style x:Key="DarkScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Style="{StaticResource DarkScrollBarStyle}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark tooltip style (applies globally in this window) -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FF1A1A1E"/>
            <Setter Property="Foreground" Value="#FFC8C8CC"/>
            <Setter Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource BluePrimary}" BlurRadius="8" ShadowDepth="0" Opacity="0.15"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark themed CheckBox style (blue accent) -->
        <Style x:Key="DarkCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder" Width="18" Height="18"
                                    CornerRadius="3" BorderThickness="1.5"
                                    BorderBrush="{StaticResource BorderBlueBrush}"
                                    Background="{StaticResource PanelDarkBrush}"
                                    VerticalAlignment="Center" Padding="1">
                                <Grid>
                                    <Path x:Name="CheckMark"
                                          Data="M 2,7 L 6,11 L 13,3"
                                          Stroke="{StaticResource BlueLightBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#333A7BD5"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource BluePrimaryBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource BlueLightBrush}"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#1A3A7BD5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#443A7BD5"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource BlueLightBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer glow + content: shadow on a sibling so content text stays crisp -->
    <Grid Margin="4">
        <!-- Shadow layer (no children → no text bitmap rendering) -->
        <Border Background="{StaticResource PanelDarkBrush}" CornerRadius="6" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="{StaticResource BluePrimary}" BlurRadius="12" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>
        </Border>
        <!-- Content layer (no effect → crisp ClearType text) -->
        <Border BorderBrush="{StaticResource BluePrimaryBrush}" BorderThickness="1.5" CornerRadius="6"
                Background="{StaticResource PanelDarkBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Navigation Bar (also serves as drag region) -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBlueBrush}" BorderThickness="0,0,0,1"
                    Background="{StaticResource PanelDarkBrush}" Padding="0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo area -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,2,0,2" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <!-- Shield + F logo -->
                            <Viewbox Width="22" Height="22" Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource BluePrimaryBrush}"
                                      Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                                    <Path Fill="White"
                                      Data="M10 7h5v2h-3v2h2.5v2H12v4h-2V7z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A7BD5" Offset="0"/>
                                        <GradientStop Color="#9B59B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="FlexTool" FontSize="18" FontWeight="Bold"/>
                            </TextBlock>
                            <Border BorderBrush="{StaticResource BluePrimaryBrush}" BorderThickness="1.5" CornerRadius="4"
                                Background="Transparent" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Preview" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource BlueLightBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Navigation tabs (evenly spaced) -->
                        <StackPanel x:Name="NavGrid" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2,0">
                            <Button Content="Dashboard" Tag="Dashboard" Style="{StaticResource NavButtonActiveStyle}" Click="NavButton_Click" Margin="2,0"/>
                            <Button Content="Mods" Tag="Mods" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Margin="2,0"/>
                            <Button Content="Configs" Tag="Configs" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Margin="2,0"/>
                            <Button Content="Changelog" Tag="Changelog" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Margin="2,0"/>
                            <Button Content="Support" Tag="Support" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Margin="2,0"/>
                        </StackPanel>

                        <!-- Notification bell + Window control buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                            <!-- Notification bell -->
                            <Button x:Name="NotificationBellButton" Style="{StaticResource WindowControlButtonStyle}" Click="NotificationBell_Click">
                                <Grid>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2" Fill="Transparent"
                                              Data="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/>
                                        </Canvas>
                                    </Viewbox>
                                    <Border x:Name="NotificationBadge" Background="#FFDC3545" CornerRadius="6"
                                        MinWidth="14" Height="14" Padding="3,0"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-4,-4,0" Visibility="Collapsed">
                                        <TextBlock x:Name="NotificationBadgeText" Text="0" FontSize="8"
                                               FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Button>
                            <!-- Minimize -->
                            <Button Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2.5" Data="M4 12h16"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Close -->
                            <Button Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2.5" Data="M6 6L18 18M18 6L6 18"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main content area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Sidebar -->
                    <Border Grid.Column="0" BorderBrush="{StaticResource BorderBlueBrush}" BorderThickness="0,0,1,0"
                        Background="{StaticResource SidebarBgBrush}">
                        <StackPanel x:Name="SidebarPanel" Margin="3,3,3,3"/>
                    </Border>

                    <!-- Right content area -->
                    <Border Grid.Column="1" Background="{StaticResource ContentBgBrush}" Margin="0" ClipToBounds="False">
                        <Grid ClipToBounds="False">
                            <!-- Page content -->
                            <Grid ClipToBounds="False">
                                <TextBlock x:Name="ContentLabel" Text="" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ScrollViewer Style="{StaticResource DarkScrollViewerStyle}"
                                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="False">
                                    <StackPanel x:Name="ContentPanel" Margin="10" ClipToBounds="False"/>
                                </ScrollViewer>
                            </Grid>

                            <!-- Toast notification container (top-right overlay) -->
                            <StackPanel x:Name="ToastContainer"
                                    VerticalAlignment="Top" HorizontalAlignment="Right"
                                    Margin="0,8,10,0" IsHitTestVisible="True"/>

                            <!-- Notification history panel (top-right dropdown) -->
                            <Border x:Name="NotificationHistoryPanel" Visibility="Collapsed"
                                VerticalAlignment="Top" HorizontalAlignment="Right"
                                Width="340" MaxHeight="420" Margin="0,0,8,0"
                                Background="{StaticResource PanelDarkBrush}"
                                BorderBrush="{StaticResource BluePrimaryBrush}"
                                BorderThickness="1" CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="14,10,14,8">
                                        <TextBlock Text="Notifications" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button x:Name="MarkAllReadBtn" Content="Mark read" FontSize="10"
                                                Foreground="{StaticResource BlueLightBrush}" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand" Padding="6,2"
                                                Click="MarkAllRead_Click"/>
                                            <Button x:Name="ClearHistoryBtn" Content="Clear" FontSize="10"
                                                Foreground="{StaticResource TextSecondaryBrush}" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand" Padding="6,2"
                                                Click="ClearHistory_Click"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              Style="{StaticResource DarkScrollViewerStyle}" Padding="0,0,0,6">
                                        <StackPanel x:Name="NotificationHistoryList" Margin="8,0,8,8"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bottom Status Bar -->
                <Border Grid.Row="2" BorderBrush="{StaticResource BorderBlueBrush}" BorderThickness="0,1,0,0"
                    Background="{StaticResource PanelDarkBrush}" Padding="16,6">
                    <DockPanel>
                        <!-- Right side: version -->
                        <TextBlock x:Name="StatusBarVersion" Text="FlexTool Preview"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" DockPanel.Dock="Right" Margin="12,0,0,0"/>

                        <!-- Left side: live status items -->
                        <StackPanel x:Name="StatusBarPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
